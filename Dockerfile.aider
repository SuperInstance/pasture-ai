# Dockerized Aider
FROM python:3.12-slim

# Install git and dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install aider
RUN pip install aider-chat

# Create a non-root user
RUN useradd -m -u 1000 aider
USER aider
WORKDIR /home/aider

# Default command
CMD ["aider", "--help"]